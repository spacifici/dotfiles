[alias]
	st = status
    stnc = -c color.status=false status
	lg = log --graph --pretty='%C(Yellow)%h  %C(Green)%aI %C(Cyan)%an: %C(Red)%d %C(reset) %s'
	bo = branchout
	co = checkout
	ff = pull --ff-only
	plog = log --oneline --no-color
	dt = difftool
	amend = commit -a --amend
[user]
	email = stefano.pacifici@gmail.com
	name = Stefano Pacifici
[color]
	ui = always
	status = always
[diff]
	tool = vimdiff
	renameLimit = 40000
[difftool]
	prompt = false
[core]
	editor = vim
[push]
	default = simple
[merge]
	tool = vimdiff
	conflictstyle = diff3
	renamelimit = 20000
[mergetool]
	prompt = false
[cinnabar]
	version-check = 1575627207
	helper = /home/stefano/projects/git-cinnabar/git-cinnabar-helper
	fsck = 1575629172
